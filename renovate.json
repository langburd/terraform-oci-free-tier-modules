{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "renovate"
  ],
  "enabledManagers": [
    "github-actions",
    "pre-commit",
    "terraform"
  ],
  "packageRules": [
    {
      "description": "Group GitHub Actions minor/patch updates and automerge",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "groupName": "GitHub Actions",
      "automerge": true
    },
    {
      "description": "Group pre-commit hook updates",
      "matchManagers": [
        "pre-commit"
      ],
      "groupName": "pre-commit hooks"
    },
    {
      "description": "Group Terraform provider updates",
      "matchManagers": [
        "terraform"
      ],
      "matchDepTypes": [
        "provider"
      ],
      "groupName": "Terraform providers"
    }
  ]
}
